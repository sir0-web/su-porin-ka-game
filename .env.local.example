# ── スイガゲーム 環境変数 ───────────────────────────────────────
# このファイルをコピーして .env.local を作り、値を入れてください。
# （.env.local は git にコミットされません）

# ランキング保存用（サーバー側・既存）
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=（Supabase ダッシュボード → Settings → API → service_role）

# 対戦モードのオンライン通信用（ブラウザ側・今回追加）
# Supabase ダッシュボード → Project Settings → API から取得：
#   NEXT_PUBLIC_SUPABASE_URL      = Project URL（上の SUPABASE_URL と同じでOK）
#   NEXT_PUBLIC_SUPABASE_ANON_KEY = "anon public" キー（service_role ではない方）
# ※ Realtime は新規プロジェクトでは既定で有効。テーブル追加は不要です。
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=（Supabase ダッシュボード → Settings → API → anon public）
